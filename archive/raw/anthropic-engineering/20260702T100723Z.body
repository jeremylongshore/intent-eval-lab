":\"theme-color\",\"content\":\"#141413\"}]]\n"])</script><script nonce="ZGRkNzc3MWItN2Y2OS00ZjdiLWIxNWYtNThjZWQzNDEwYWY5">self.__next_f.push([1,"6:[\"$\",\"$L15\",null,{\"page\":{\"_createdAt\":\"2025-01-15T15:45:48Z\",\"_id\":\"8eaf3767-6721-42f3-859e-a543f19d47ce\",\"_rev\":\"3R9N6zTx1UJr6GwDEwhCSk\",\"_type\":\"page\",\"_updatedAt\":\"2025-01-24T13:34:54Z\",\"backgroundColor\":\"default\",\"internalPageType\":\"anthropic\",\"meta\":{\"robotsIndexable\":true,\"socialImage\":null},\"sections\":[{\"_createdAt\":\"2025-01-15T16:29:10Z\",\"_id\":\"e17da550-f3b8-4db6-9468-450735111295\",\"_rev\":\"9WHkd7ITmHwRqYoHFwNhuw\",\"_type\":\"blogCta\",\"_updatedAt\":\"2025-01-24T13:32:45Z\",\"backgroundColor\":\"default\",\"ctas\":[{\"_createdAt\":\"2024-06-14T02:42:09Z\",\"_id\":\"5ecc0939-7b84-446a-86bb-4513944611ed\",\"_rev\":\"7w637SJGtiNyz4h6VRy1Jf\",\"_system\":{\"base\":{\"id\":\"5ecc0939-7b84-446a-86bb-4513944611ed\",\"rev\":\"NfzXt1G7gAUPwOoLHVYuuE\"}},\"_type\":\"link\",\"_updatedAt\":\"2026-01-12T15:18:32Z\",\"fileAsset\":null,\"modalId\":null,\"page\":null,\"text\":\"Start building\",\"url\":\"https://platform.claude.com/\"},{\"_createdAt\":\"2024-04-30T03:32:58Z\",\"_id\":\"900f626a-f2ac-45cf-acc6-663ba72f2449\",\"_rev\":\"KjfwYzvigf84lpRLe5Pre4\",\"_type\":\"link\",\"_updatedAt\":\"2024-04-30T03:47:13Z\",\"fileAsset\":null,\"modalId\":null,\"page\":null,\"text\":\"Developer docs\",\"url\":\"https://www.anthropic.com/docs\"}],\"flushBottom\":true,\"flushTop\":false,\"internalName\":\"Engineering Nav Cta\",\"title\":\"Engineering at Anthropic: Inside the team building reliable AI systems\"},{\"_createdAt\":\"2025-01-15T16:29:34Z\",\"_id\":\"2e2c486e-e54f-4f6f-afa9-a2ccbb2ff50e\",\"_rev\":\"3R9N6zTx1UJr6GwDEwfuqj\",\"_type\":\"articleList\",\"_updatedAt\":\"2025-01-24T13:38:39Z\",\"articles\":[{\"_type\":\"engineeringArticle\",\"cardImage\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-47d14a71a7a759af39e1bc36ee68d65eb16ad74d-1000x1000-svg\",\"_type\":\"reference\"},\"height\":1000,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/47d14a71a7a759af39e1bc36ee68d65eb16ad74d-1000x1000.svg\",\"width\":1000},\"publishedOn\":\"2026-05-25\",\"slug\":{\"_type\":\"slug\",\"current\":\"how-we-contain-claude\"},\"spotIllustration\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-641d32b3291956d595c7e820d5bf94c5f44baa28-500x500-svg\",\"_type\":\"reference\"},\"height\":500,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/641d32b3291956d595c7e820d5bf94c5f44baa28-500x500.svg\",\"width\":500},\"subjects\":[{\"_key\":\"architecture\",\"_type\":\"tag\",\"label\":\"Architecture\",\"value\":\"architecture\"}],\"summary\":\"As agents grow more capable, so does their potential blast radius. The engineering question is how to cap it. Here’s what we’ve learned building containment for claude.ai, Claude Code, and Cowork.\\n\",\"title\":\"How we contain Claude across products\"},{\"_type\":\"engineeringArticle\",\"cardImage\":null,\"publishedOn\":\"2026-04-23\",\"slug\":{\"_type\":\"slug\",\"current\":\"april-23-postmortem\"},\"spotIllustration\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-259cb9466c31eee1bd312c230c1ab95c844da488-500x500-svg\",\"_type\":\"reference\"},\"height\":500,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/259cb9466c31eee1bd312c230c1ab95c844da488-500x500.svg\",\"width\":500},\"subjects\":[{\"_key\":\"performance\",\"_type\":\"tag\",\"label\":\"Performance\",\"value\":\"performance\"}],\"summary\":\"We traced recent reports of Claude Code quality issues to three separate changes. Here's what happened and what we're changing.\",\"title\":\"An update on recent Claude Code quality reports\"},{\"_type\":\"engineeringArticle\",\"cardImage\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-282c56ae3ec0a72a15c5f4186744ce0ac940a2dd-2554x2554-svg\",\"_type\":\"reference\"},\"height\":2554,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/282c56ae3ec0a72a15c5f4186744ce0ac940a2dd-2554x2554.svg\",\"width\":2554},\"publishedOn\":\"2026-04-08\",\"slug\":{\"_type\":\"slug\",\"current\":\"managed-agents\"},\"spotIllustration\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-7675e9c4ed4c7a8fe2e4df296fd1c4adac5b652b-1200x1200-svg\",\"_type\":\"reference\"},\"height\":1200,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/7675e9c4ed4c7a8fe2e4df296fd1c4adac5b652b-1200x1200.svg\",\"width\":1200},\"subjects\":[{\"_key\":\"architecture\",\"_type\":\"tag\",\"label\":\"Architecture\",\"value\":\"architecture\"}],\"summary\":\"Harnesses encode assumptions that go stale as models improve. Managed Agents—our hosted service for long-horizon agent work—is built around interfaces that stay stable as harnesses change.\",\"title\":\"Scaling Managed Agents: Decoupling the brain from the hands\"},{\"_type\":\"engineeringArticle\",\"cardImage\":null,\"publishedOn\":\"2026-03-25\",\"slug\":{\"_type\":\"slug\",\"current\":\"claude-code-auto-mode\"},\"spotIllustration\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-b87185e4d533134bc3f9b949a874396dcfcb2e80-500x500-svg\",\"_type\":\"reference\"},\"height\":500,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/b87185e4d533134bc3f9b949a874396dcfcb2e80-500x500.svg\",\"width\":500},\"subjects\":[{\"_key\":\"architecture\",\"_type\":\"tag\",\"label\":\"Architecture\",\"value\":\"architecture\"}],\"summary\":\"Claude Code users approve 93% of permission prompts. We built classifiers to automate some decisions, increasing safety while reducing approval fatigue. Here's what it catches, and what it misses.\\n\",\"title\":\"How we built Claude Code auto mode: a safer way to skip permissions\"},{\"_type\":\"engineeringArticle\",\"cardImage\":null,\"publishedOn\":\"2026-03-24\",\"slug\":{\"_type\":\"slug\",\"current\":\"harness-design-long-running-apps\"},\"spotIllustration\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-af0acebfbd57ac4b26ae7d7ae124d7326a3e47e4-1200x1200-svg\",\"_type\":\"reference\"},\"height\":1200,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/af0acebfbd57ac4b26ae7d7ae124d7326a3e47e4-1200x1200.svg\",\"width\":1200},\"subjects\":[{\"_key\":\"developer-tools\",\"_type\":\"tag\",\"label\":\"Developer Tools\",\"value\":\"developer-tools\"}],\"summary\":\"Harness design is key to performance at the frontier of agentic coding. Here's how we pushed Claude further in frontend design and long-running autonomous software engineering.\",\"title\":\"Harness design for long-running application development\"},{\"_type\":\"engineeringArticle\",\"cardImage\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-47d14a71a7a759af39e1bc36ee68d65eb16ad74d-1000x1000-svg\",\"_type\":\"reference\"},\"height\":1000,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/47d14a71a7a759af39e1bc36ee68d65eb16ad74d-1000x1000.svg\",\"width\":1000},\"publishedOn\":\"2026-03-06\",\"slug\":{\"_type\":\"slug\",\"current\":\"eval-awareness-browsecomp\"},\"spotIllustration\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-641d32b3291956d595c7e820d5bf94c5f44baa28-500x500-svg\",\"_type\":\"reference\"},\"height\":500,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/641d32b3291956d595c7e820d5bf94c5f44baa28-500x500.svg\",\"width\":500},\"subjects\":[{\"_key\":\"testing\",\"_type\":\"tag\",\"label\":\"Testing\",\"value\":\"testing\"}],\"summary\":\"Evaluating Opus 4.6 on BrowseComp, we found cases where the model recognized the test, then found and decrypted answers to it—raising questions about eval integrity in web-enabled environments.\",\"title\":\"Eval awareness in Claude Opus 4.6’s BrowseComp performance\"},{\"_type\":\"engineeringArticle\",\"cardImage\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-d428d11fcf4123ff0d0859d03fba459ad4d3d01a-2554x2554-svg\",\"_type\":\"reference\"},\"height\":2554,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/d428d11fcf4123ff0d0859d03fba459ad4d3d01a-2554x2554.svg\",\"width\":2554},\"publishedOn\":\"2026-02-05\",\"slug\":{\"_type\":\"slug\",\"current\":\"infrastructure-noise\"},\"spotIllustration\":null,\"subjects\":[{\"_key\":\"architecture\",\"_type\":\"tag\",\"label\":\"Architecture\",\"value\":\"architecture\"}],\"summary\":\"Infrastructure configuration can swing agentic coding benchmarks by several percentage points—sometimes more than the leaderboard gap between top models.\\n\\n\",\"title\":\"Quantifying infrastructure noise in agentic coding evals\"},{\"_type\":\"engineeringArticle\",\"cardImage\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-7e2e39544a35760367049072406377a54f2b58c0-2554x2554-svg\",\"_type\":\"reference\"},\"height\":2554,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/7e2e39544a35760367049072406377a54f2b58c0-2554x2554.svg\",\"width\":2554},\"publishedOn\":\"2026-02-05\",\"slug\":{\"_type\":\"slug\",\"current\":\"building-c-compiler\"},\"spotIllustration\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-44e93e074d53285f64ff717365b04c4a2164a445-1200x1200-svg\",\"_type\":\"reference\"},\"height\":1200,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/44e93e074d53285f64ff717365b04c4a2164a445-1200x1200.svg\",\"width\":1200},\"subjects\":[{\"_key\":\"developer-tools\",\"_type\":\"tag\",\"label\":\"Developer Tools\",\"value\":\"developer-tools\"}],\"summary\":\"We tasked Opus 4.6 using agent teams to build a C Compiler, and then (mostly) walked away. Here's what it taught us about the future of autonomous software development.\",\"title\":\"Building a C compiler with a team of parallel Claudes\"},{\"_type\":\"engineeringArticle\",\"cardImage\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-097b92aa686c266a8fcdd890a491641273d3dae5-2554x2554-svg\",\"_type\":\"reference\"},\"height\":2554,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/097b92aa686c266a8fcdd890a491641273d3dae5-2554x2554.svg\",\"width\":2554},\"publishedOn\":\"2026-01-21\",\"slug\":{\"_type\":\"slug\",\"current\":\"AI-resistant-technical-evaluations\"},\"spotIllustration\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-dc34c3eeae881b105ef652d5630d84de6a1fa01a-1200x1200-svg\",\"_type\":\"reference\"},\"height\":1200,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/dc34c3eeae881b105ef652d5630d84de6a1fa01a-1200x1200.svg\",\"width\":1200},\"subjects\":[{\"_key\":\"performance\",\"_type\":\"tag\",\"label\":\"Performance\",\"value\":\"performance\"}],\"summary\":\"What we learned from three iterations of a performance engineering take-home that Claude keeps beating.\",\"title\":\"Designing AI-resistant technical evaluations\"},{\"_type\":\"engineeringArticle\",\"cardImage\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-590360609ccdf39715a8ec6916b52447dcb31f16-1000x1000-svg\",\"_type\":\"reference\"},\"height\":1000,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/590360609ccdf39715a8ec6916b52447dcb31f16-1000x1000.svg\",\"width\":1000},\"publishedOn\":\"2026-01-09\",\"slug\":{\"_type\":\"slug\",\"current\":\"demystifying-evals-for-ai-agents\"},\"spotIllustration\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-b87185e4d533134bc3f9b949a874396dcfcb2e80-500x500-svg\",\"_type\":\"reference\"},\"height\":500,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/b87185e4d533134bc3f9b949a874396dcfcb2e80-500x500.svg\",\"width\":500},\"subjects\":[{\"_key\":\"testing\",\"_type\":\"tag\",\"label\":\"Testing\",\"value\":\"testing\"}],\"summary\":\"The capabilities that make agents useful also make them difficult to evaluate. The strategies that work across deployments combine techniques to match the complexity of the systems they measure. \\n\",\"title\":\"Demystifying evals for AI agents\"},{\"_type\":\"engineeringArticle\",\"cardImage\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-5dfb835ad3cbbf76b85824e969146eac20329e72-1000x1000-svg\",\"_type\":\"reference\"},\"height\":1000,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/5dfb835ad3cbbf76b85824e969146eac20329e72-1000x1000.svg\",\"width\":1000},\"publishedOn\":\"2025-11-26\",\"slug\":{\"_type\":\"slug\",\"current\":\"effective-harnesses-for-long-running-agents\"},\"spotIllustration\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-c041b5e0498972014414a7c3d044727982f26bde-500x500-svg\",\"_type\":\"reference\"},\"height\":500,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/c041b5e0498972014414a7c3d044727982f26bde-500x500.svg\",\"width\":500},\"subjects\":[{\"_key\":\"developer-tools\",\"_type\":\"tag\",\"label\":\"Developer Tools\",\"value\":\"developer-tools\"}],\"summary\":\"Agents still face challenges working across many context windows. We looked to human engineers for inspiration in creating a more effective harness for long-running agents.\",\"title\":\"Effective harnesses for long-running agents\"},{\"_type\":\"engineeringArticle\",\"cardImage\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-151600be7f9c23247aad8dcb6aacb2e1ab024f44-1000x1000-svg\",\"_type\":\"reference\"},\"description\":\"Illustration for advanced tool use article.\",\"height\":1000,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/151600be7f9c23247aad8dcb6aacb2e1ab024f44-1000x1000.svg\",\"width\":1000},\"publishedOn\":\"2025-11-24\",\"slug\":{\"_type\":\"slug\",\"current\":\"advanced-tool-use\"},\"spotIllustration\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-2aa849e93e76ae567502dcae2db8921062531fa1-500x500-svg\",\"_type\":\"reference\"},\"description\":\"Illustration for advanced tool use article.\",\"height\":500,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/2aa849e93e76ae567502dcae2db8921062531fa1-500x500.svg\",\"width\":500},\"subjects\":[{\"_key\":\"developer-tools\",\"_type\":\"tag\",\"label\":\"Developer Tools\",\"value\":\"developer-tools\"}],\"summary\":\"We’ve added three new beta features that let Claude discover, learn, and execute tools dynamically. Here’s how they work.\",\"title\":\"Introducing advanced tool use on the Claude Developer Platform\"},{\"_type\":\"engineeringArticle\",\"cardImage\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-42f40f6fae9ec2d7cf2e5a98908a16d0216b91be-1000x1000-svg\",\"_type\":\"reference\"},\"height\":1000,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/42f40f6fae9ec2d7cf2e5a98908a16d0216b91be-1000x1000.svg\",\"width\":1000},\"publishedOn\":\"2025-11-04\",\"slug\":{\"_type\":\"slug\",\"current\":\"code-execution-with-mcp\"},\"spotIllustration\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-848e961961a97ada3a7edb2d1d17378792c3288d-500x500-svg\",\"_type\":\"reference\"},\"height\":500,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/848e961961a97ada3a7edb2d1d17378792c3288d-500x500.svg\",\"width\":500},\"subjects\":[{\"_key\":\"open-source\",\"_type\":\"tag\",\"label\":\"Open Source\",\"value\":\"open-source\"}],\"summary\":\"Direct tool calls consume context for each definition and result. Agents scale better by writing code to call tools instead. Here's how it works with MCP.\",\"title\":\"Code execution with MCP: Building more efficient agents\"},{\"_type\":\"engineeringArticle\",\"cardImage\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-0321b0ecbbf53535e93be1310ae1935157bcebdd-1000x1000-svg\",\"_type\":\"reference\"},\"height\":1000,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/0321b0ecbbf53535e93be1310ae1935157bcebdd-1000x1000.svg\",\"width\":1000},\"publishedOn\":\"2025-10-20\",\"slug\":{\"_type\":\"slug\",\"current\":\"claude-code-sandboxing\"},\"spotIllustration\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-33d37e1ae729f4e960d11fecf143ac14c0fb369d-500x500-svg\",\"_type\":\"reference\"},\"height\":500,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/33d37e1ae729f4e960d11fecf143ac14c0fb369d-500x500.svg\",\"width\":500},\"subjects\":[{\"_key\":\"developer-tools\",\"_type\":\"tag\",\"label\":\"Developer Tools\",\"value\":\"developer-tools\"}],\"summary\":\"Claude Code's new sandboxing features, a bash tool and Claude Code on the web,  reduce permission prompts and increase user safety by enabling two boundaries: filesystem and network isolation. \",\"title\":\"Beyond permission prompts: making Claude Code more secure and autonomous\"},{\"_type\":\"engineeringArticle\",\"cardImage\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-b52f6dbff1c4323ef2371ba0ac50df994835435a-1000x1000-svg\",\"_type\":\"reference\"},\"height\":1000,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/b52f6dbff1c4323ef2371ba0ac50df994835435a-1000x1000.svg\",\"width\":1000},\"publishedOn\":\"2025-10-16\",\"slug\":{\"_type\":\"slug\",\"current\":\"equipping-agents-for-the-real-world-with-agent-skills\"},\"spotIllustration\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-b4fe0845239779c6fc1e045edb6272c3f500944a-500x500-svg\",\"_type\":\"reference\"},\"height\":500,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/b4fe0845239779c6fc1e045edb6272c3f500944a-500x500.svg\",\"width\":500},\"subjects\":[{\"_key\":\"architecture\",\"_type\":\"tag\",\"label\":\"Architecture\",\"value\":\"architecture\"}],\"summary\":\"Claude is powerful, but real work requires procedural knowledge and organizational context. Introducing Agent Skills, a new way to build specialized agents using files and folders.\",\"title\":\"Equipping agents for the real world with Agent Skills\"},{\"_type\":\"engineeringArticle\",\"cardImage\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-33b03d9dd1e6aec266ef22a616aec8f5676223f6-1000x1000-svg\",\"_type\":\"reference\"},\"height\":1000,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/33b03d9dd1e6aec266ef22a616aec8f5676223f6-1000x1000.svg\",\"width\":1000},\"publishedOn\":\"2025-09-29\",\"slug\":{\"_type\":\"slug\",\"current\":\"effective-context-engineering-for-ai-agents\"},\"spotIllustration\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-a048404a96b599af98c05da5bdd1db07222e4e7b-500x500-svg\",\"_type\":\"reference\"},\"height\":500,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/a048404a96b599af98c05da5bdd1db07222e4e7b-500x500.svg\",\"width\":500},\"subjects\":[{\"_key\":\"Agents\",\"_type\":\"tag\",\"label\":\"Agents\",\"value\":\"Agents\"}],\"summary\":\"Context is a critical but finite resource for AI agents. In this post, we explore strategies for effectively curating and managing the context that powers them.\",\"title\":\"Effective context engineering for AI agents\"},{\"_type\":\"engineeringArticle\",\"cardImage\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-0321b0ecbbf53535e93be1310ae1935157bcebdd-1000x1000-svg\",\"_type\":\"reference\"},\"height\":1000,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/0321b0ecbbf53535e93be1310ae1935157bcebdd-1000x1000.svg\",\"width\":1000},\"publishedOn\":\"2025-09-17\",\"slug\":{\"_type\":\"slug\",\"current\":\"a-postmortem-of-three-recent-issues\"},\"spotIllustration\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-33d37e1ae729f4e960d11fecf143ac14c0fb369d-500x500-svg\",\"_type\":\"reference\"},\"height\":500,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/33d37e1ae729f4e960d11fecf143ac14c0fb369d-500x500.svg\",\"width\":500},\"subjects\":[{\"_key\":\"performance\",\"_type\":\"tag\",\"label\":\"Performance\",\"value\":\"performance\"}],\"summary\":\"This is a technical report on three bugs that intermittently degraded responses from Claude. Below we explain what happened, why it took time to fix, and what we're changing.\",\"title\":\"A postmortem of three recent issues\"},{\"_type\":\"engineeringArticle\",\"cardImage\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-876165247ba5668bd195854eef4631ad9a184001-1000x1000-svg\",\"_type\":\"reference\"},\"description\":\"This is an abstract illustration for the Eng Blog article, Writing effective tools for agents -- with agents.\",\"height\":1000,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/876165247ba5668bd195854eef4631ad9a184001-1000x1000.svg\",\"width\":1000},\"publishedOn\":\"2025-09-11\",\"slug\":{\"_type\":\"slug\",\"current\":\"writing-tools-for-agents\"},\"spotIllustration\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-b4fe0845239779c6fc1e045edb6272c3f500944a-500x500-svg\",\"_type\":\"reference\"},\"description\":\"This is an abstract illustration for the Eng Blog article, Writing effective tools for agents -- with agents.\",\"height\":500,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/b4fe0845239779c6fc1e045edb6272c3f500944a-500x500.svg\",\"width\":500},\"subjects\":[{\"_key\":\"architecture\",\"_type\":\"tag\",\"label\":\"Architecture\",\"value\":\"architecture\"},{\"_key\":\"developer-tools\",\"_type\":\"tag\",\"label\":\"Developer Tools\",\"value\":\"developer-tools\"}],\"summary\":\"Agents are only as effective as the tools we give them. We share how to write high-quality tools and evaluations, and how you can boost performance by using Claude to optimize its tools for itself.\",\"title\":\"Writing effective tools for agents — with agents\"},{\"_type\":\"engineeringArticle\",\"cardImage\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-1d7118b992792989576d23bb279bbf3e38c37618-1000x1000-svg\",\"_type\":\"reference\"},\"height\":1000,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/1d7118b992792989576d23bb279bbf3e38c37618-1000x1000.svg\",\"width\":1000},\"publishedOn\":\"2025-06-26\",\"slug\":{\"_type\":\"slug\",\"current\":\"desktop-extensions\"},\"spotIllustration\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-dde35f184e14e5c37b0b3ab5a1c0bbad06ac123b-500x500-svg\",\"_type\":\"reference\"},\"height\":500,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/dde35f184e14e5c37b0b3ab5a1c0bbad06ac123b-500x500.svg\",\"width\":500},\"subjects\":[{\"_key\":\"developer-tools\",\"_type\":\"tag\",\"label\":\"Developer Tools\",\"value\":\"developer-tools\"},{\"_key\":\"open-source\",\"_type\":\"tag\",\"label\":\"Open Source\",\"value\":\"open-source\"}],\"summary\":\"Desktop Extensions make installing MCP servers as easy as clicking a button. We share the technical architecture and tips for creating good extensions.\",\"title\":\"Desktop Extensions: One-click MCP server installation for Claude Desktop\"},{\"_type\":\"engineeringArticle\",\"cardImage\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-094d7021ebd5cf57eabd63b456899c97f5231c88-1000x1000-svg\",\"_type\":\"reference\"},\"height\":1000,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/094d7021ebd5cf57eabd63b456899c97f5231c88-1000x1000.svg\",\"width\":1000},\"publishedOn\":\"2025-06-13\",\"slug\":{\"_type\":\"slug\",\"current\":\"multi-agent-research-system\"},\"spotIllustration\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-848e961961a97ada3a7edb2d1d17378792c3288d-500x500-svg\",\"_type\":\"reference\"},\"height\":500,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/848e961961a97ada3a7edb2d1d17378792c3288d-500x500.svg\",\"width\":500},\"subjects\":[{\"_key\":\"architecture\",\"_type\":\"tag\",\"label\":\"Architecture\",\"value\":\"architecture\"}],\"summary\":\"Our Research feature uses multiple Claude agents to explore complex topics more effectively. We share the engineering challenges and the lessons we learned from building this system.\",\"title\":\"How we built our multi-agent research system\"},{\"_type\":\"engineeringArticle\",\"cardImage\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-6295100fcf8952bed666ba69536c581af87eef15-2554x2554-svg\",\"_type\":\"reference\"},\"height\":2554,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/6295100fcf8952bed666ba69536c581af87eef15-2554x2554.svg\",\"width\":2554},\"publishedOn\":\"2025-04-18\",\"slug\":{\"_type\":\"slug\",\"current\":\"claude-code-best-practices\"},\"spotIllustration\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-c423cdaa6733c03a5d10f38c76e1ecf1900c6716-1200x1200-svg\",\"_type\":\"reference\"},\"height\":1200,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/c423cdaa6733c03a5d10f38c76e1ecf1900c6716-1200x1200.svg\",\"width\":1200},\"subjects\":[{\"_key\":\"developer-tools\",\"_type\":\"tag\",\"label\":\"Developer Tools\",\"value\":\"developer-tools\"}],\"summary\":\"Claude Code is a command line tool for agentic coding. This post covers tips and tricks that have proven effective for using Claude Code across various codebases, languages, and environments. \",\"title\":\"Claude Code: Best practices for agentic coding\"},{\"_type\":\"engineeringArticle\",\"cardImage\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-0baf46071c5ff97684a8dfe51e90f27ef27c1cef-2554x2554-svg\",\"_type\":\"reference\"},\"description\":\"Abstract shapes illustrating Anthropic's Engineering Blog\",\"height\":2554,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/0baf46071c5ff97684a8dfe51e90f27ef27c1cef-2554x2554.svg\",\"width\":2554},\"publishedOn\":\"2025-03-20\",\"slug\":{\"_type\":\"slug\",\"current\":\"claude-think-tool\"},\"spotIllustration\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-461ea9ed02230ba02ab830e5a5b23df66ea23bc8-1200x1200-svg\",\"_type\":\"reference\"},\"description\":\"Abstract shapes illustrating Anthropic's Engineering Blog\",\"height\":1200,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/461ea9ed02230ba02ab830e5a5b23df66ea23bc8-1200x1200.svg\",\"width\":1200},\"subjects\":[{\"_key\":\"developer-tools\",\"_type\":\"tag\",\"label\":\"Developer Tools\",\"value\":\"developer-tools\"}],\"summary\":\"A new tool that improves Claude's complex problem-solving performance\",\"title\":\"The \\\"think\\\" tool: Enabling Claude to stop and think in complex tool use situations\"},{\"_type\":\"engineeringArticle\",\"cardImage\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-290e18c396589364580e2432e96d7d96724338a7-2554x2554-svg\",\"_type\":\"reference\"},\"height\":2554,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/290e18c396589364580e2432e96d7d96724338a7-2554x2554.svg\",\"width\":2554},\"publishedOn\":\"2025-01-06\",\"slug\":{\"_type\":\"slug\",\"current\":\"swe-bench-sonnet\"},\"spotIllustration\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-ef693b8c4ebfcead4e17af7bd87b66f8bc70b8cc-1200x1200-svg\",\"_type\":\"reference\"},\"height\":1200,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/ef693b8c4ebfcead4e17af7bd87b66f8bc70b8cc-1200x1200.svg\",\"width\":1200},\"subjects\":[{\"_key\":\"testing\",\"_type\":\"tag\",\"label\":\"Testing\",\"value\":\"testing\"}],\"summary\":\"SWE-bench is an AI evaluation benchmark that assesses a model's ability to complete real-world software engineering tasks.\",\"title\":\"Raising the bar on SWE-bench Verified with Claude 3.5 Sonnet\"},{\"_type\":\"engineeringArticle\",\"cardImage\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-039b6648c28eb33070a63a58d49013600b229238-2554x2554-svg\",\"_type\":\"reference\"},\"height\":2554,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/039b6648c28eb33070a63a58d49013600b229238-2554x2554.svg\",\"width\":2554},\"publishedOn\":\"2024-12-19\",\"slug\":{\"_type\":\"slug\",\"current\":\"building-effective-agents\"},\"spotIllustration\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-14b20fce6e93c79be47352da0fa4bebd597ebfa8-1200x1200-svg\",\"_type\":\"reference\"},\"height\":1200,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/14b20fce6e93c79be47352da0fa4bebd597ebfa8-1200x1200.svg\",\"width\":1200},\"subjects\":[{\"_key\":\"architecture\",\"_type\":\"tag\",\"label\":\"Architecture\",\"value\":\"architecture\"}],\"summary\":\"We've worked with dozens of teams building LLM agents across industries. Consistently, the most successful implementations use simple, composable patterns rather than complex frameworks. \",\"title\":\"Building effective agents\"},{\"_type\":\"engineeringArticle\",\"cardImage\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-7e2e39544a35760367049072406377a54f2b58c0-2554x2554-svg\",\"_type\":\"reference\"},\"height\":2554,\"url\":\"https://cdn.sanity.io/images/4zrzovbb/website/7e2e39544a35760367049072406377a54f2b58c0-2554x2554.svg\",\"width\":2554},\"publishedOn\":\"2024-09-19\",\"slug\":{\"_type\":\"slug\",\"current\":\"contextual-retrieval\"},\"spotI