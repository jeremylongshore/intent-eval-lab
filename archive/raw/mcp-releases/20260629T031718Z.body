  <entry>
    <id>tag:github.com,2008:Repository/862570523/2024-11-05-final</id>
    <updated>2025-03-26T13:53:30Z</updated>
    <link rel="alternate" type="text/html" href="https://github.com/modelcontextprotocol/modelcontextprotocol/releases/tag/2024-11-05-final"/>
    <title>2024-11-05-final</title>
    <content type="html">&lt;p&gt;This release marks the final 2024-11-05 revision of the Model Context Protocol, including all backwards compatible changes made since &lt;a href=&quot;https://github.com/modelcontextprotocol/specification/releases/tag/2024-11-05&quot;&gt;the initial 2024-11-05 release&lt;/a&gt;.&lt;/p&gt;</content>
