  <entry>
    <id>tag:github.com,2008:Grit::Commit/ca1e7dc13c0ab5e2dfaa6de71991cd951b8f1cf2</id>
    <link type="text/html" rel="alternate" href="https://github.com/anthropics/skills/commit/ca1e7dc13c0ab5e2dfaa6de71991cd951b8f1cf2"/>
    <title>
        Update claude-api skill with Managed Agents guidance (#891)
    </title>
    <updated>2026-04-08T17:01:02Z</updated>
    <media:thumbnail height="30" width="30" url="https://avatars.githubusercontent.com/u/27286675?s=30&amp;v=4"/>
    <author>
      <name>ericharmeling</name>
      <uri>https://github.com/ericharmeling</uri>
