}), \"\\n\", _jsx(Heading, {\n      level: \"3\",\n      id: \"key-principles\",\n      children: \"Key Principles\"\n    }), \"\\n\", _jsxs(_components.ol, {\n      children: [\"\\n\", _jsxs(_components.li, {\n        children: [\"\\n\", _jsx(_components.p, {\n          children: _jsx(_components.strong, {\n            children: \"User Consent and Control\"\n          })\n        }), \"\\n\", _jsxs(_components.ul, {\n          children: [\"\\n\", _jsx(_components.li, {\n            children: \"Users must explicitly consent to and understand all data access and operations\"\n          }), \"\\n\", _jsx(_components.li, {\n            children: \"Users must retain control over what data is shared and what actions are taken\"\n          }), \"\\n\", _jsx(_components.li, {\n            children: \"Implementors should provide clear UIs for reviewing and authorizing activities\"\n          }), \"\\n\"]\n        }), \"\\n\"]\n      }), \"\\n\", _jsxs(_components.li, {\n        children: [\"\\n\", _jsx(_components.p, {\n          children: _jsx(_components.strong, {\n            children: \"Data Privacy\"\n          })\n        }), \"\\n\", _jsxs(_components.ul, {\n          children: [\"\\n\", _jsx(_components.li, {\n            children: \"Hosts must obtain explicit user consent before exposing user data to servers\"\n          }), \"\\n\", _jsx(_components.li, {\n            children: \"Hosts must not transmit resource data elsewhere without user consent\"\n          }), \"\\n\", _jsx(_components.li, {\n            children: \"User data should be protected with appropriate access controls\"\n          }), \"\\n\"]\n        }), \"\\n\"]\n      }), \"\\n\", _jsxs(_components.li, {\n        children: [\"\\n\", _jsx(_components.p, {\n          children: _jsx(_components.strong, {\n            children: \"Tool Safety\"\n          })\n        }), \"\\n\", _jsxs(_components.ul, {\n          children: [\"\\n\", _jsxs(_components.li, {\n            children: [\"Tools represent arbitrary code execution and must be treated with appropriate\\ncaution.\", \"\\n\", _jsxs(_components.ul, {\n              children: [\"\\n\", _jsx(_components.li, {\n                children: \"In particular, descriptions of tool behavior such as annotations should be\\nconsidered untrusted, unless obtained from a trusted server.\"\n              }), \"\\n\"]\n            }), \"\\n\"]\n          }), \"\\n\", _jsx(_components.li, {\n            children: \"Hosts must obtain explicit user consent before invoking any tool\"\n          }), \"\\n\", _jsx(_components.li, {\n            children: \"Users should understand what each tool does before authorizing its use\"\n          }), \"\\n\"]\n        }), \"\\n\"]\n      }), \"\\n\"]\n    }), \"\\n\", _jsx(Heading, {\n      level: \"3\",\n      id: \"implementation-guidelines\",\n      children: \"Implementation Guidelines\"\n    }), \"\\n\", _jsxs(_components.p, {\n      children: [\"While MCP itself cannot enforce these security principles at the protocol level,\\nimplementors \", _jsx(_components.strong, {\n        children: \"SHOULD\"\n      }), \":\"]\n    }), \"\\n\", _jsxs(_components.ol, {\n      children: [\"\\n\", _jsx(_components.li, {\n        children: \"Build robust consent and authorization flows into their applications\"\n      }), \"\\n\", _jsx(_components.li, {\n        children: \"Provide clear documentation of security implications\"\n      }), \"\\n\", _jsx(_components.li, {\n        children: \"Implement appropriate access controls and data protections\"\n      }), \"\\n\", _jsx(_components.li, {\n        children: \"Follow security best practices in their integrations\"\n      }), \"\\n\", _jsx(_components.li, {\n        children: \"Consider privacy implications in their feature designs\"\n      }), \"\\n\"]\n    }), \"\\n\", _jsx(Heading, {\n      level: \"2\",\n      id: \"learn-more\",\n      children: \"Learn More\"\n    }), \"\\n\", _jsx(_components.p, {\n      children: \"Explore the detailed 