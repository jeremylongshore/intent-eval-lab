# intent-eval-lab umbrella .gitignore
# Constituent projects (in projects/) have their own .gitignore — those are symlinks, ignored at this level

# Private operational notes (engagement details, patent-sensitive cross-refs, sock-puppet observations)
.private/

# Symlinks to constituent projects — they live at their original paths, no need to track here
projects/

# Evidence artifacts — generally too large / ephemeral / contain raw OTEL traces with potential PII
evidence/**/*.json
evidence/**/*.png
evidence/**/*.html
evidence/**/*.zip
evidence/**/*.log
# But DO track REPORT.md and the structure
!evidence/**/REPORT.md
!evidence/**/.gitkeep

# Sandbox docker volumes + ephemeral state
sandboxes/**/data/
sandboxes/**/volumes/
sandboxes/**/.env
sandboxes/**/cookies.json
sandboxes/**/postgres-data/

# OS / editor noise
.DS_Store
._*
Thumbs.db
*.swp
*.swo
*~

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node
node_modules/
.pnpm-store/

# Direnv / local env
.envrc
.env.local
.env.*.local

# Test caches
.pytest_cache/
.eslintcache
coverage/
*.lcov
.lycheecache

# Build outputs
dist/
build/
out/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# >>> sops-init managed block (do not edit this fence) >>>
# Plaintext secrets — block explicitly. Encrypted forms (.env.sops, *.sops.yaml) are committed.
.env
.env.local
.env.dev
.env.staging
.env.prod
secrets.dev.yaml
secrets.staging.yaml
secrets.prod.yaml
*.pem
*.key
secrets/
credentials/
# SOPS temp files (decrypted to /dev/shm during sops-env exec)
*.sops.tmp
# <<< sops-init managed block <<<

# Coverage subprocess instrumentation artifacts
.coverage
.coverage.*

# Phase A.0 signing artifacts are DURABLE, publicly-citable evidence — track them
# explicitly (the general evidence/ ignore above is for ephemeral run telemetry).
!evidence/phase-a-0-baseline/evidence-bundle.json
!evidence/phase-a-0-baseline/evidence-bundle.sigstore.json

# CoreWeave dogfood signed-evidence bundles are DURABLE, publicly-citable
# evidence — track them explicitly (same rule as phase-a-0 above; each new
# bundle here is a deliberate allowlist decision, per the gated-signing
# runbook).
!evidence/coreweave-dogfood/*.bundle.json

# Snapshot-currency gate-result/v1 row (iel-E07 residual; DR-010 Q3 unification
# thesis) — the spec-drift-watch run emits + commits this each audit/cron run.
# It is DURABLE evidence (the latest snapshot-currency verdict), not ephemeral
# telemetry, so track it explicitly past the evidence/**/*.json ignore above.
!evidence/snapshot-currency/gate-result.json
